# Twaylo OS — checklist complète des variables (spec Partie 9).
# Copier en .env.local pour le développement, puis pousser sur Vercel pour la prod.
# Les lignes marquées [étape N] ne servent pas encore : les laisser vides.

# --- Supabase ------------------------------------------------------------
# Tableau de bord Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authentification ----------------------------------------------------
# AUTH_SECRET : openssl rand -hex 32
AUTH_SECRET=
# Le mot de passe qui ouvre le dashboard. À choisir mémorable.
DASHBOARD_PASSWORD=
# Accès programmatique (cron, CLI) via l'en-tête x-api-secret.
API_SECRET=

# --- LLM ---------------------------------------------------------- [étape 3]
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=

# --- Telegram ----------------------------------------------------- [étape 3]
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USER_ID=

# --- YouTube / AdSense / Agenda ----------------------------------- [étape 5]
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
GOOGLE_CALENDAR_ICAL_URL=

# --- Divers --------------------------------------------------------------
CRON_SECRET=
USER_ID=twaylo
# Exposé au client : le fuseau sert aussi au calcul du jour local côté navigateur.
NEXT_PUBLIC_USER_TIMEZONE=Europe/Paris

# Google Agenda, en lecture seule.
# Agenda › survoler l'agenda › Paramètres › « Adresse secrète au format iCal ».
# Cette URL vaut lecture complète de l'agenda : elle reste côté serveur et
# n'est jamais renvoyée au navigateur. La régénérer depuis Google révoque
# l'ancienne.
GOOGLE_ICAL_URL=
